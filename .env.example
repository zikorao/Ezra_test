# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# service_role secret — JWT with role "service_role" (NOT the anon key)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM providers (use one in production)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
GROQ_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MCP / programmatic API (generate: node scripts/generate-api-key.mjs)
ARTIFACT_HUB_API_KEY=your-artifact-hub-api-key
