# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# service_role secret — JWT with role "service_role" (NOT the anon key)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Personal access token for npm run migrate:* scripts (https://supabase.com/dashboard/account/tokens)
# SUPABASE_ACCESS_TOKEN=sbp_...

# ── LLM (metadata, search, rerank, autocomplete, feedback digest) ──
# Local dev: ollama pull llama3.2
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Production (Vercel): LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Embeddings for semantic search (768-dim pgvector) ──
# Local: ollama pull nomic-embed-text
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBED_MODEL=nomic-embed-text

# Production (Vercel): EMBEDDING_PROVIDER=jina
JINA_API_KEY=

# Optional alternative embedding provider
OPENAI_API_KEY=

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MCP / programmatic API (generate: npm run api-key)
ARTIFACT_HUB_API_KEY=your-artifact-hub-api-key

# ── Phoenix observability (free tier: https://app.phoenix.arize.com) ──
# Settings → copy Collector Endpoint + API Key for your space
PHOENIX_API_KEY=
# Phoenix Cloud default; override with your space hostname from Settings if needed
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
PHOENIX_PROJECT_NAME=artifact-hub
# PHOENIX_BATCH=true   # optional; default is immediate export (better for Vercel serverless)
# Local: pip install arize-phoenix && phoenix serve  →  http://localhost:6006

# ── Vercel Analytics + OTEL correlation (Step 12) ──
# Enable Web Analytics in the Vercel dashboard (no env vars required).
# @vercel/otel registers automatically via instrumentation.ts.
# API routes return x-trace-id headers; client events include trace_id for correlation.
# See docs/observability-dashboards.md

# ── Rate limiting (Supabase migration 004) ──
# Required for enforcement: npm run migrate:rate-limit (see docs/rate-limiting.md)
# RATE_LIMIT_SEARCH_SUGGEST_PER_MIN=60
# RATE_LIMIT_SEARCH_QUERY_PER_MIN=20
# RATE_LIMIT_DIGEST_PER_10MIN=5
# RATE_LIMIT_DIGEST_PER_ARTIFACT_5MIN=2
# RATE_LIMIT_MCP_SEARCH_PER_MIN=60
