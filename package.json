{
  "name": "artifact-hub",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "build": "npm run build --workspace=web",
    "start": "npm run start --workspace=web",
    "lint": "npm run lint --workspace=web",
    "seed": "node scripts/seed-artifacts.mjs",
    "seed:more": "node scripts/seed-more-artifacts.mjs",
    "seed:all": "node scripts/seed-artifacts.mjs && node scripts/seed-more-artifacts.mjs",
    "seed:feedback": "node scripts/seed-feedback.mjs",
    "seed:demo": "node scripts/seed-artifacts.mjs && node scripts/seed-more-artifacts.mjs && node scripts/seed-feedback.mjs",
    "index": "node scripts/index-artifacts.mjs",
    "index:force": "FORCE_REINDEX=1 node scripts/index-artifacts.mjs",
    "migrate:search": "node scripts/apply-search-migration.mjs",
    "migrate:rate-limit": "node scripts/apply-rate-limit-migration.mjs",
    "mcp": "npm run start --workspace=@artifact-hub/mcp-server",
    "api-key": "node scripts/generate-api-key.mjs",
    "test:observability": "node scripts/test-observability.mjs"
  }
}
